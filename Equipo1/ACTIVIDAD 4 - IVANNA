#Digitos
def pedirNumeros():
   num = int(input("Dame un número entero: "))
   return num

def analisis_de_Numeros(num):
   num_str = str(num)
   #Elimina el signo negativo si existe
   if num_str.startswith("-"):
      num_str = num_str[1:]

   if not num_str.isdigit():
       print("Error: Debe ser número entero.")
       return

   longitud = len(num_str)

   if longitud == 1:
       print("El número tiene un dígito.")

   elif longitud == 2:
       print("El número tiene dos dígitos.")

   elif longitud == 3:
       print("El número tiene tres dígitos.")

   else:
       print("El número tiene más de tres dígitos.")

#Programa Principal
numero = pedirNumeros()
analisis_de_Numeros(numero)

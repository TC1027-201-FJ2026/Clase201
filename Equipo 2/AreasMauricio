import math

# Función que despliega el menú
def menu():
    print("1) Área del Triángulo")
    print("2) Área del Círculo")
    print("3) Área del Cuadrado")
    print("4) Área del Rectángulo")
    opcion = int(input("¿Qué área deseas realizar? "))
    operaciones(opcion)

# Función que calcula el área según la opción
def operaciones(op):
    if op == 1:
        base = float(input("Dame la base: "))
        altura = float(input("Dame la altura: "))
        area = base * altura / 2
        print(f"El área del triángulo con base {base} y altura {altura} es: {round(area, 4)}")
    elif op == 2:
        radio = float(input("Dame el radio: "))
        area = math.pi * radio ** 2
        print(f"El área del círculo con radio {int(radio)} es: {round(area, 4)}")
    elif op == 3:
        lado = float(input("Dame el lado: "))
        area = lado ** 2
        print(f"El área del cuadrado con lado {lado} es: {round(area, 4)}")
    elif op == 4:
        base = float(input("Dame la base: "))
        altura = float(input("Dame la altura: "))
        area = base * altura
        print(f"El área del rectángulo con base {base} y altura {altura} es: {round(area, 4)}")
    else:
        print("La opción no existe.")
    print("\nADIOS")

# Llamada
menu()
